<% content_for :title, "P2" %>

<div class="min-h-screen bg-gray-50">

  <nav class="bg-white border-b border-gray-100 px-6 py-4 flex items-center justify-between">
    <span class="text-lg font-bold text-gray-900">P2</span>
    <div class="flex items-center gap-4 text-sm">
      <% if logged_in? %>
        <span class="text-gray-600"><%= current_employee.full_name %></span>
        <%= button_to "Sign out", logout_path, method: :delete,
            class: "text-gray-500 hover:text-gray-900 cursor-pointer bg-transparent border-0 p-0" %>
      <% else %>
        <%= link_to "Sign in", login_path, class: "text-blue-600 hover:underline font-medium" %>
      <% end %>
    </div>
  </nav>

  <% if flash[:notice] %>
    <div class="max-w-2xl mx-auto mt-4 px-4">
      <div class="rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        <%= flash[:notice] %>
      </div>
    </div>
  <% end %>

  <div class="max-w-2xl mx-auto px-4 py-16 text-center">
    <h1 class="text-5xl font-bold text-gray-900 mb-4">P2</h1>
    <p class="text-xl text-gray-500 mb-10">Application is running.</p>

    <% if logged_in? %>
      <div class="flex flex-wrap justify-center gap-3 mb-10">
        <%= link_to "File Uploads", uploads_path,
            class: "inline-flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 shadow-sm transition-colors" %>
      </div>
    <% end %>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-left">
      <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <div class="text-2xl mb-2">⚙️</div>
        <h2 class="font-semibold text-gray-800 mb-1">Rails 7.2</h2>
        <p class="text-sm text-gray-500">Ruby on Rails running on Puma with MySQL.</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <div class="text-2xl mb-2">☁️</div>
        <h2 class="font-semibold text-gray-800 mb-1">Google Cloud</h2>
        <p class="text-sm text-gray-500">Hosted on GCP Compute Engine with Cloud SQL.</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <div class="text-2xl mb-2">✅</div>
        <h2 class="font-semibold text-gray-800 mb-1">Health Check</h2>
        <p class="text-sm text-gray-500">Monitor status at <a href="/up" class="text-blue-500 hover:underline">/up</a>.</p>
      </div>
    </div>
  </div>

</div>
