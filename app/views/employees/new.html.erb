<% content_for :title, "Sign Up" %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-10">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">P2</h1>
      <p class="text-gray-500 mt-1">Create your account</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">

      <% if @employee.errors.any? %>
        <div class="mb-5 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
          <p class="font-medium mb-1">Please fix the following:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% @employee.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @employee, url: signup_path, method: :post do |f| %>

        <div class="grid grid-cols-2 gap-4 mb-5">
          <div>
            <%= f.label :fn, "First name", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :fn,
                autofocus: true,
                autocomplete: "given-name",
                value: @employee.fn,
                class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
                placeholder: "First" %>
          </div>
          <div>
            <%= f.label :ln, "Last name", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :ln,
                autocomplete: "family-name",
                value: @employee.ln,
                class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
                placeholder: "Last" %>
          </div>
        </div>

        <div class="mb-5">
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email,
              autocomplete: "email",
              value: @employee.email,
              class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              placeholder: "you@example.com" %>
        </div>

        <div class="mb-5">
          <%= f.label :login, "Username", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :login,
              autocomplete: "username",
              value: @employee.login,
              class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              placeholder: "Letters, numbers, underscores" %>
        </div>

        <div class="mb-5">
          <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              placeholder: "Minimum 6 characters" %>
        </div>

        <div class="mb-6">
          <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              placeholder: "••••••••" %>
        </div>

        <%= f.submit "Create account",
            class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-4 rounded-lg text-sm cursor-pointer transition-colors" %>
      <% end %>

      <div class="mt-5 text-center text-sm text-gray-500">
        Already have an account?
        <%= link_to "Sign in", login_path, class: "text-blue-600 hover:underline font-medium" %>
      </div>

    </div>
  </div>
</div>
