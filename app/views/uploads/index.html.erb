<% content_for :title, "File Uploads" %>

<div class="max-w-3xl mx-auto px-4 py-10">

  <h1 class="text-2xl font-semibold text-gray-800 mb-8">File Uploads</h1>

  <% if flash[:notice] %>
    <div class="mb-5 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
      <%= flash[:notice] %>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div class="mb-5 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%# Upload form %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-8">
    <h2 class="text-sm font-medium text-gray-700 mb-4">Upload a file</h2>
    <%= form_with url: uploads_path, method: :post, multipart: true do |f| %>
      <div class="flex items-center gap-3">
        <%= f.file_field :file,
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer" %>
        <%= f.submit "Upload",
            class: "shrink-0 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-5 rounded-lg text-sm cursor-pointer transition-colors" %>
      </div>
    <% end %>
  </div>

  <%# File list %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <% if @files.empty? %>
      <p class="px-6 py-8 text-sm text-gray-400 text-center">No files uploaded yet.</p>
    <% else %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50">
            <th class="text-left px-6 py-3 font-medium text-gray-500">File name</th>
            <th class="text-right px-6 py-3 font-medium text-gray-500">Size</th>
            <th class="text-right px-6 py-3 font-medium text-gray-500">Uploaded</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody>
          <% @files.each do |file| %>
            <tr class="border-b border-gray-50 hover:bg-gray-50">
              <td class="px-6 py-3 text-gray-800 font-medium break-all"><%= file[:name] %></td>
              <td class="px-6 py-3 text-gray-500 text-right whitespace-nowrap"><%= number_to_human_size(file[:size]) %></td>
              <td class="px-6 py-3 text-gray-500 text-right whitespace-nowrap"><%= file[:modified_at].strftime("%b %-d, %Y %H:%M") %></td>
              <td class="px-6 py-3 text-right whitespace-nowrap">
                <%= link_to "Download", download_upload_path(file[:name]),
                    class: "text-blue-600 hover:underline mr-3" %>
                <%= button_to "Delete", upload_path(file[:name]), method: :delete,
                    data: { turbo_confirm: "Delete \"#{file[:name]}\"?" },
                    class: "text-red-500 hover:underline bg-transparent border-0 p-0 cursor-pointer text-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

</div>
