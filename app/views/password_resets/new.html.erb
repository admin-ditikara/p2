<% content_for :title, "Forgot Password" %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">P2</h1>
      <p class="text-gray-500 mt-1">Reset your password</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">

      <% if flash[:alert] %>
        <div class="mb-5 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <p class="text-sm text-gray-600 mb-5">
        Enter the email address associated with your account and we'll generate a reset link for you.
      </p>

      <%= form_with url: password_resets_path, method: :post do |f| %>
        <div class="mb-6">
          <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              placeholder: "you@example.com" %>
        </div>

        <%= f.submit "Send reset link",
            class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-4 rounded-lg text-sm cursor-pointer transition-colors" %>
      <% end %>

      <div class="mt-5 text-center text-sm">
        <%= link_to "Back to sign in", login_path, class: "text-blue-600 hover:underline" %>
      </div>

    </div>
  </div>
</div>
