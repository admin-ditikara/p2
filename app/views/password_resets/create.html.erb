<% content_for :title, "Reset Link Ready" %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">P2</h1>
      <p class="text-gray-500 mt-1">Password reset link</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">

      <div class="flex items-center gap-2 mb-4">
        <div class="text-green-500 text-xl">✓</div>
        <p class="text-sm font-medium text-gray-800">Reset link generated successfully</p>
      </div>

      <p class="text-sm text-gray-600 mb-4">
        Use the link below to set a new password. It expires in <strong>1 hour</strong>.
      </p>

      <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 break-all text-xs text-gray-700 font-mono mb-6">
        <%= link_to @reset_url, @reset_url, class: "text-blue-600 hover:underline" %>
      </div>

      <%= link_to "Go to reset page", @reset_url,
          class: "block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-4 rounded-lg text-sm transition-colors" %>

      <div class="mt-5 text-center text-sm">
        <%= link_to "Back to sign in", login_path, class: "text-blue-600 hover:underline" %>
      </div>

    </div>
  </div>
</div>
